# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=6091
SERVER_READ_TIMEOUT=5m
SERVER_WRITE_TIMEOUT=10m
SERVER_SHUTDOWN_TIMEOUT=15s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=zencial
DB_PASSWORD=zencial_secret
DB_NAME=zencial
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h
JWT_ISSUER=zencial

# Storage (S3/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=zencial-videos
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# CDN
CDN_BASE_URL=
CDN_SIGNING_KEY_ID=
CDN_SIGNING_KEY_PATH=
CDN_URL_EXPIRY=4h

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
