# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=6091
SERVER_READ_TIMEOUT=5m
SERVER_WRITE_TIMEOUT=10m
SERVER_SHUTDOWN_TIMEOUT=15s
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=zencial
DB_PASSWORD=zencial_secret
DB_NAME=zencial
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Storage (S3/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=videos
S3_REGION=eu-west-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Session (Default values)
SESSION_IDLE_TIMEOUT=720h
SESSION_ABSOLUTE_TIMEOUT=2160h
SESSION_SLIDE_DEBOUNCE=5m
SESSION_CLEANUP_INTERVAL=1h

# CDN
CDN_BASE_URL=localhost:8090
CDN_URL_EXPIRY=4h
CDN_UPLOAD_SIGNING_KEY=change-me-cdn-upload-signing-key

# Internal service-to-service API (CDN transcode-completion callbacks).
# Required when CDN integration is enabled. Must match VOD_CALLBACK_SECRET in zencial-cdn.
INTERNAL_API_SHARED_SECRET=change-me-internal-secret

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=usd

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
